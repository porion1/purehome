{
  "name": "purehome-notification-service",
  "version": "1.0.0",
  "description": "FAANG-level notification service with 12 proprietary algorithms, 50M+ concurrent users, handles email/SMS/push at scale",
  "author": "PureHomes Engineering",
  "license": "UNLICENSED",
  "main": "src/server.js",
  "engine": "node >=20.0.0",
  "scripts": {
    "start": "NODE_ENV=production node src/server.js",
    "dev": "NODE_ENV=development nodemon src/server.js",
    "cluster": "NODE_ENV=production node src/server.js --cluster",
    "test": "jest --coverage --runInBand",
    "test:load": "artillery run test/load/spike-test.yml",
    "lint": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\""
  },
  "dependencies": {
    "express": "4.18.2",
    "mongoose": "8.0.0",
    "jsonwebtoken": "9.0.2",
    "axios": "1.7.7",
    "nodemailer": "6.9.7",
    "handlebars": "4.7.8",
    "redis": "4.6.12",
    "bull": "4.11.5",
    "winston": "3.11.0",
    "prom-client": "15.0.0",
    "helmet": "7.0.0",
    "cors": "2.8.5",
    "compression": "1.7.4",
    "express-rate-limit": "7.1.5",
    "crypto": "1.0.1",
    "dotenv": "16.3.1"
  },
  "devDependencies": {
    "nodemon": "3.0.1",
    "jest": "29.7.0",
    "supertest": "6.3.3",
    "artillery": "2.0.0-31",
    "eslint": "8.56.0",
    "prettier": "3.1.1"
  },
  "keywords": [
    "notification-service",
    "email-service",
    "sms-service",
    "push-notifications",
    "faang-level",
    "microservices",
    "50m-users"
  ]
}