{
  "name": "payment-service",
  "version": "4.0.0",
  "description": "🚀 FAANG-Level Payment Processing Engine — 50M Users Ready | Zero Duplicate Charges | Distributed Idempotency | Real-time Fraud Detection | Predictive Circuit Breakers | Adaptive Tracing",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:debug": "nodemon --inspect",
    "prod": "NODE_ENV=production node server.js",
    "test": "jest --coverage --runInBand",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.js\"",
    "health": "node scripts/healthCheck.js",
    "seed": "node scripts/seed.js",
    "migrate": "node scripts/migrate.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "pre-commit": "lint-staged",
    "prepare": "husky install"
  },
  "keywords": [
    "payment-processing",
    "stripe-integration",
    "idempotency",
    "circuit-breaker",
    "distributed-locking",
    "event-sourcing",
    "fraud-detection",
    "50m-scale",
    "faang-level",
    "microservices",
    "payment-gateway"
  ],
  "author": "PureHomes Payment Team",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@opentelemetry/api": "1.6.0",
    "@opentelemetry/exporter-jaeger": "1.18.0",
    "@opentelemetry/instrumentation-express": "0.37.0",
    "@opentelemetry/instrumentation-http": "0.43.0",
    "@opentelemetry/instrumentation-mongodb": "0.40.0",
    "@opentelemetry/sdk-node": "0.43.0",
    "axios": "1.7.7",
    "bcryptjs": "2.4.3",
    "bull": "4.11.5",
    "busboy": "1.6.0",
    "compression": "1.7.4",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "express": "4.18.2",
    "express-rate-limit": "6.10.0",
    "express-validator": "7.0.1",
    "helmet": "7.0.0",
    "ioredis": "5.3.2",
    "joi": "17.10.0",
    "jsonwebtoken": "9.0.2",
    "mongoose": "7.5.0",
    "node-cache": "5.1.2",
    "object-hash": "3.0.0",
    "pino": "8.15.0",
    "pino-pretty": "10.2.0",
    "prom-client": "14.2.0",
    "redis": "4.6.7",
    "redlock": "5.0.0-beta.2",
    "stripe": "14.0.0",
    "uuid": "9.0.0",
    "winston": "3.10.0",
    "winston-daily-rotate-file": "4.7.1"
  },
  "devDependencies": {
    "@faker-js/faker": "8.0.2",
    "eslint": "8.49.0",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-plugin-import": "2.28.1",
    "eslint-plugin-jest": "27.2.3",
    "husky": "8.0.3",
    "jest": "29.6.4",
    "lint-staged": "14.0.1",
    "mongodb-memory-server": "8.15.1",
    "nock": "13.3.3",
    "nodemon": "^3.0.1",
    "prettier": "3.0.3",
    "sinon": "15.2.0",
    "supertest": "6.3.3"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "branches": 85,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    },
    "collectCoverageFrom": [
      "**/*.js",
      "!**/node_modules/**",
      "!**/tests/**",
      "!**/scripts/**",
      "!**/coverage/**"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ]
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "app.js",
      "config",
      "controllers",
      "integrations",
      "middleware",
      "models",
      "routes",
      "services",
      "utils",
      "monitoring"
    ],
    "ext": "js,json",
    "ignore": [
      "tests",
      "node_modules"
    ],
    "exec": "node server.js",
    "env": {
      "NODE_ENV": "development",
      "LOG_LEVEL": "debug"
    }
  },
  "docker": {
    "image": "payment-service",
    "port": 5004,
    "env": {
      "NODE_ENV": "production",
      "MAX_MEMORY": "2048M",
      "MAX_CPUS": 2
    }
  }
}
