{
  "service": {
    "name": "purehomes-order-service",
    "version": "3.0.0",
    "description": "FAANG-level order management microservice with 14 proprietary algorithms for 50M+ concurrent users",
    "port": 5003,
    "baseUrl": "http://localhost:5003",
    "apiMountPoint": "/api/orders",
    "database": "MongoDB",
    "databaseName": "purehomes",
    "architecture": "Microservice",
    "capacity": "50M+ concurrent users",
    "status": "PRODUCTION_READY"
  },

  "algorithms": [
    {
      "name": "RIO",
      "fullName": "Reservation-Integrated Ordering",
      "purpose": "Two-phase commit with DIRE reservations",
      "location": "orderController.js",
      "formula": "abandonmentProb = (anomalyScore × 0.6) + (cartValue × 0.2) + (timeOfDay × 0.2)"
    },
    {
      "name": "DCR",
      "fullName": "Dynamic Circuit Routing",
      "purpose": "Service mesh health monitoring",
      "location": "orderRoutes.js",
      "formula": "healthScore = (successRate × 0.5) + (latencyScore × 0.3) + ((1 - errorPenalty) × 0.2)"
    },
    {
      "name": "DOSA",
      "fullName": "Dynamic Order Scoring Algorithm",
      "purpose": "Priority scoring for orders",
      "location": "orderModel.js",
      "formula": "priorityScore = (userWeight × 0.4) + (stockWeight × 0.4) + (timeWeight × 0.2)"
    },
    {
      "name": "ARS",
      "fullName": "Adaptive Request Shaping",
      "purpose": "Rate limiting with predictive backpressure",
      "location": "server.js",
      "formula": "dynamicRate = baseRate × (1 - errorRate) × √(availableConnections)"
    },
    {
      "name": "DLBA",
      "fullName": "Dynamic Load Balancing Algorithm",
      "purpose": "Request distribution across cores",
      "location": "server.js",
      "formula": "loadScore = (currentRequests / maxConcurrent) × (latency / 1000)"
    },
    {
      "name": "HERMES",
      "fullName": "Hierarchical Event Routing with Multi-tier Exponential Scaling",
      "purpose": "Webhook delivery with retry and circuit breaking",
      "location": "webhookController.js",
      "formula": "backoffDelay = min(maxDelay, baseDelay × (2^retryCount) + jitter)"
    },
    {
      "name": "SIREN",
      "fullName": "Secure Intelligent Relay with Event Notification",
      "purpose": "Event streaming and notification",
      "location": "webhookController.js",
      "formula": "eventPriority = (orderAmount × 0.4) + (userTier × 0.3) + (eventAge × 0.3)"
    },
    {
      "name": "SPHINX",
      "fullName": "Search Parsing with Hierarchical Indexing for Nexus eXecution",
      "purpose": "Multi-field search with relevance scoring",
      "location": "searchController.js",
      "formula": "relevanceScore = (fieldWeight × matchQuality) + (recencyBoost × 0.1) + (frequencyBoost × 0.05)"
    },
    {
      "name": "PRISM",
      "fullName": "Progressive Range Indexing for Scalable Metrics",
      "purpose": "Range filtering with faceted aggregation",
      "location": "searchController.js",
      "formula": "indexScore = (fieldCardinality × 0.4) + (queryFrequency × 0.3) + (rangeSelectivity × 0.3)"
    },
    {
      "name": "TIDES",
      "fullName": "Temporal Intelligence for Dynamic Exponential Smoothing",
      "purpose": "Time-series forecasting analytics",
      "location": "analyticsController.js",
      "formula": "level_t = α × value_t + (1-α) × (level_{t-1} + trend_{t-1})"
    },
    {
      "name": "HELIX",
      "fullName": "Hierarchical Exponential Learning for Intelligent eXecution",
      "purpose": "Product ranking with velocity scoring",
      "location": "analyticsController.js",
      "formula": "rankScore = velocityScore × (1 + recencyBoost) × categoryMultiplier"
    },
    {
      "name": "BATCH",
      "fullName": "Bulk Adaptive Transaction Chunking Handler",
      "purpose": "Intelligent batch processing",
      "location": "bulkController.js",
      "formula": "optimalChunkSize = baseChunk × (1 - loadFactor) × (1 - errorRate)"
    },
    {
      "name": "STREAM",
      "fullName": "Scalable Throughput with Real-time Export Aggregation Manager",
      "purpose": "Memory-efficient streaming export",
      "location": "bulkController.js",
      "formula": "compressionRatio = originalSize / compressedSize"
    },
    {
      "name": "PHOENIX",
      "fullName": "Predictive Historical Order Execution with Neural Index eXecution",
      "purpose": "1-click reorder with stock validation",
      "location": "reorderController.js",
      "formula": "adjustedQuantity = min(originalQuantity, availableStock × 0.8)"
    },
    {
      "name": "TRACK",
      "fullName": "Tracking & Real-time Analytics with Carrier Knowledge",
      "purpose": "Shipment tracking with predictive delivery",
      "location": "reorderController.js",
      "formula": "predictedDelivery = shipDate + (avgTransitDays × weatherFactor × holidayFactor)"
    },
    {
      "name": "PENDULUM",
      "fullName": "Pending Order Discovery & Unified Listing Utility Module",
      "purpose": "Admin pending orders aggregation",
      "location": "orderController.js",
      "formula": "estimatedConversionValue = pendingRevenue × historicalConversionRate"
    },
    {
      "name": "ABACUS",
      "fullName": "Abandoned Basket Analytics & Cumulative Unified Scoring",
      "purpose": "Abandoned cart detection with recovery scoring",
      "location": "orderController.js",
      "formula": "recoveryScore = (valueScore × 0.5) + (ageScore × 0.3) + (userLoyaltyFactor × 0.2)"
    }
  ],

  "endpoints": {
    "coreOperations": [
      { "method": "POST", "path": "/", "algorithm": "RIO", "auth": true, "description": "Create order with reservation" },
      { "method": "GET", "path": "/:id", "algorithm": "-", "auth": true, "description": "Get order by ID" },
      { "method": "GET", "path": "/user/:userId", "algorithm": "-", "auth": true, "description": "Get user's orders" },
      { "method": "PUT", "path": "/:id/status", "algorithm": "-", "auth": true, "description": "Update order status (Admin)" },
      { "method": "DELETE", "path": "/:id", "algorithm": "RIO", "auth": true, "description": "Cancel order" },
      { "method": "POST", "path": "/:id/confirm", "algorithm": "RIO", "auth": true, "description": "Confirm payment" }
    ],
    "reorderAndTracking": [
      { "method": "POST", "path": "/:id/reorder", "algorithm": "PHOENIX", "auth": true, "description": "1-click reorder" },
      { "method": "GET", "path": "/:id/tracking", "algorithm": "TRACK", "auth": true, "description": "Get shipment tracking" },
      { "method": "POST", "path": "/bulk/reorder", "algorithm": "PHOENIX", "auth": true, "description": "Bulk reorder" },
      { "method": "GET", "path": "/reorder/stats", "algorithm": "-", "auth": true, "description": "User reorder statistics" }
    ],
    "searchAndFilter": [
      { "method": "GET", "path": "/search", "algorithm": "SPHINX", "auth": true, "description": "Multi-field search" },
      { "method": "GET", "path": "/filter", "algorithm": "PRISM", "auth": true, "description": "Range filtering with facets" },
      { "method": "GET", "path": "/search/suggest", "algorithm": "-", "auth": true, "description": "Autocomplete suggestions" },
      { "method": "POST", "path": "/search/cache/invalidate", "algorithm": "-", "auth": true, "description": "Clear search cache" }
    ],
    "analytics": [
      { "method": "GET", "path": "/analytics/daily", "algorithm": "TIDES", "auth": true, "description": "Daily analytics with forecasting" },
      { "method": "GET", "path": "/analytics/top-products", "algorithm": "HELIX", "auth": true, "description": "Top products ranking" },
      { "method": "POST", "path": "/analytics/cache/invalidate", "algorithm": "-", "auth": true, "description": "Clear analytics cache" }
    ],
    "bulkOperations": [
      { "method": "POST", "path": "/bulk/cancel", "algorithm": "BATCH", "auth": true, "description": "Bulk cancel orders" },
      { "method": "POST", "path": "/bulk/export", "algorithm": "STREAM", "auth": true, "description": "Bulk export (JSON/CSV)" },
      { "method": "GET", "path": "/bulk/export/status/:exportId", "algorithm": "STREAM", "auth": true, "description": "Export job status" },
      { "method": "GET", "path": "/bulk/download/:exportId", "algorithm": "STREAM", "auth": true, "description": "Download export" },
      { "method": "POST", "path": "/bulk/retry/:jobId", "algorithm": "BATCH", "auth": true, "description": "Retry failed batch items" },
      { "method": "GET", "path": "/bulk/dead-letter", "algorithm": "BATCH", "auth": true, "description": "Dead letter queue" }
    ],
    "webhooks": [
      { "method": "POST", "path": "/webhooks/order-created", "algorithm": "HERMES", "auth": true, "description": "Order created webhook" },
      { "method": "POST", "path": "/webhooks/order-paid", "algorithm": "HERMES", "auth": true, "description": "Order paid webhook" },
      { "method": "POST", "path": "/webhooks/subscribe", "algorithm": "-", "auth": true, "description": "Register webhook subscriber" },
      { "method": "GET", "path": "/webhooks/stats", "algorithm": "SIREN", "auth": true, "description": "Webhook delivery stats" },
      { "method": "GET", "path": "/webhooks/dead-letter", "algorithm": "HERMES", "auth": true, "description": "Dead letter queue" },
      { "method": "POST", "path": "/webhooks/retry/:index", "algorithm": "HERMES", "auth": true, "description": "Retry failed webhook" },
      { "method": "GET", "path": "/webhooks/events", "algorithm": "SIREN", "auth": true, "description": "Event stream" }
    ],
    "adminDashboard": [
      { "method": "GET", "path": "/admin/orders/pending", "algorithm": "PENDULUM", "auth": true, "description": "Pending orders (Admin)" },
      { "method": "GET", "path": "/admin/orders/abandoned-carts", "algorithm": "ABACUS", "auth": true, "description": "Abandoned carts (Admin)" }
    ],
    "monitoring": [
      { "method": "GET", "path": "/dcr/status", "algorithm": "DCR", "auth": true, "description": "Circuit breaker status" },
      { "method": "GET", "path": "/metrics/rio", "algorithm": "RIO", "auth": true, "description": "RIO metrics" },
      { "method": "GET", "path": "/health/dashboard", "algorithm": "-", "auth": true, "description": "Service health dashboard" },
      { "method": "GET", "path": "/health/ready", "algorithm": "-", "auth": false, "description": "K8s readiness probe" },
      { "method": "GET", "path": "/health/live", "algorithm": "-", "auth": false, "description": "K8s liveness probe" }
    ]
  },

  "fileStructure": {
    "server.js": "Entry point, middleware setup (ARS, DLBA, CHRONOS)",
    "config/db.js": "MongoDB connection (ADCS, PCB-ALS)",
    "models/Order.js": "Order schema (DOSA, RIO)",
    "controllers/orderController.js": "Main operations (AOPA, RIO, PENDULUM, ABACUS)",
    "controllers/analyticsController.js": "Analytics (TIDES, HELIX)",
    "controllers/bulkController.js": "Bulk operations (BATCH, STREAM)",
    "controllers/searchController.js": "Search/Filter (SPHINX, PRISM)",
    "controllers/reorderController.js": "Reorder/Tracking (PHOENIX, TRACK)",
    "controllers/webhookController.js": "Webhooks/Events (HERMES, SIREN)",
    "routes/orderRoutes.js": "Route definitions (IRT, DCR)",
    "middleware/authMiddleware.js": "JWT auth (ATTE, TPS)",
    "middleware/validateInput.js": "Input validation (AIVE, CIVET)",
    "services/productService.js": "Product Service integration (ACA, PROMETHEUS)",
    "services/userService.js": "User Service integration (AUFA, ATHENA)",
    "utils/orderScoring.js": "Priority scoring (DOSA, PHOENIX)"
  },

  "externalDependencies": [
    { "service": "User Service", "port": 5001, "endpoint": "/api/users/me", "purpose": "User validation, SIF anomaly scores" },
    { "service": "Product Service", "port": 5002, "endpoint": "/products/:id", "purpose": "Product info, inventory heat maps" },
    { "service": "Product Service (DIRE)", "port": 5002, "endpoint": "/products/:id/reserve-stock", "purpose": "Stock reservation" },
    { "database": "MongoDB", "port": 27017, "name": "purehomes", "purpose": "Data persistence" }
  ],

  "environmentVariables": {
    "required": [
      { "name": "PORT", "default": "5003", "description": "Service port" },
      { "name": "MONGO_URI", "default": "mongodb://127.0.0.1:27017/purehomes", "description": "MongoDB connection" },
      { "name": "JWT_SECRET", "default": "UserServiceSecret123!@", "description": "JWT secret (must match User Service)" },
      { "name": "USER_SERVICE_URL", "default": "http://localhost:5001", "description": "User Service URL" },
      { "name": "PRODUCT_SERVICE_URL", "default": "http://localhost:5002", "description": "Product Service URL" }
    ],
    "optional": [
      { "name": "ARS_ENABLED", "default": "true", "description": "Adaptive Request Shaping" },
      { "name": "ARS_TOKEN_CAPACITY", "default": "10000", "description": "Max concurrent tokens" },
      { "name": "ARS_BASE_REFILL_RATE", "default": "5000", "description": "Tokens per second" },
      { "name": "LOG_LEVEL", "default": "debug", "description": "Logging level" },
      { "name": "MONGO_URI_FALLBACK", "default": "mongodb://127.0.0.1:27018/purehomes", "description": "Fallback MongoDB" }
    ]
  },

  "databaseSchema": {
    "collection": "orders",
    "fields": {
      "user": { "type": "Object", "required": true },
      "user.userId": { "type": "String", "required": true, "index": true },
      "user.email": { "type": "String", "required": true },
      "user.name": { "type": "String", "required": true },
      "user.isGuest": { "type": "Boolean", "default": false },
      "user.securityContext.anomalyScore": { "type": "Number" },
      "user.securityContext.riskLevel": { "type": "String" },
      "products": { "type": "Array", "required": true },
      "products[].productId": { "type": "String", "required": true },
      "products[].variantId": { "type": "String", "required": true },
      "products[].name": { "type": "String", "required": true },
      "products[].quantity": { "type": "Number", "required": true, "min": 1, "max": 999 },
      "products[].priceAtPurchase": { "type": "Number", "required": true },
      "products[].reservation.reservationId": { "type": "String", "unique": true, "sparse": true },
      "products[].reservation.status": { "type": "String", "enum": ["pending", "confirmed", "expired", "released"], "default": "pending" },
      "products[].reservation.expiresAt": { "type": "Date" },
      "products[].productSnapshot.category": { "type": "String" },
      "subtotal": { "type": "Number", "required": true },
      "tax": { "type": "Number", "default": 0 },
      "shippingCost": { "type": "Number", "default": 0 },
      "totalAmount": { "type": "Number", "required": true },
      "priorityScore": { "type": "Number", "default": 0, "index": true },
      "idempotencyKey": { "type": "String", "unique": true, "required": true, "index": true },
      "twoPhaseState": { "type": "String", "enum": ["INITIATED", "RESERVATIONS_PENDING", "RESERVATIONS_CONFIRMED", "PAYMENT_PENDING", "COMPLETED", "FAILED", "ROLLBACK"], "default": "INITIATED" },
      "status": { "type": "String", "enum": ["pending_payment", "payment_received", "processing", "shipped", "delivered", "cancelled", "failed"], "default": "pending_payment", "index": true },
      "createdAt": { "type": "Date", "default": "Date.now", "index": true },
      "paidAt": { "type": "Date" },
      "cancelledAt": { "type": "Date" }
    }
  },

  "auth": {
    "type": "JWT Bearer Token",
    "expiry": "15 minutes",
    "roles": ["user", "admin"],
    "tokenHeader": "Authorization: Bearer <token>"
  },

  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --coverage",
    "lint": "eslint . --fix",
    "format": "prettier --write \"**/*.js\"",
    "security:audit": "npm audit && npm audit fix"
  },

  "deployment": {
    "container": {
      "image": "purehomes/order-service:latest",
      "port": 5003,
      "healthCheck": "/health/ready",
      "resources": {
        "requests": { "cpu": "500m", "memory": "512Mi" },
        "limits": { "cpu": "2000m", "memory": "2Gi" }
      }
    },
    "kubernetes": {
      "replicas": 3,
      "readinessProbe": "/health/ready",
      "livenessProbe": "/health/live",
      "hpa": {
        "enabled": true,
        "minReplicas": 2,
        "maxReplicas": 50,
        "targetCPUUtilization": 70
      }
    }
  },

  "monitoring": {
    "metrics": "/api/orders/metrics/rio",
    "health": "/api/orders/health/dashboard",
    "circuitBreaker": "/api/orders/dcr/status",
    "readiness": "/health/ready",
    "liveness": "/health/live"
  }
}