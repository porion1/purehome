{
  "name": "purehomes-order-service",
  "version": "2.0.0",
  "description": "Order microservice for PureHomes platform. FAANG-level MVP with Adaptive Order Scoring (DOSA), Predictive Circuit Breaking (PCB-ALS), and Intelligent Request Shaping (IRS).",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint . --fix",
    "format": "prettier --write \"**/*.js\"",
    "security:audit": "npm audit && npm audit fix",
    "security:check": "npx audit-ci --critical",
    "health": "node scripts/health-check.js",
    "metrics": "node scripts/metrics-reporter.js",
    "loadtest": "artillery run load-test.yml",
    "score:order": "node scripts/calculate-score.js",
    "score:batch": "node scripts/batch-scoring.js",
    "irs:status": "node scripts/irs-status.js",
    "irs:reset": "node scripts/irs-reset.js",
    "irs:config": "node scripts/irs-configure.js",
    "horus:analyze": "node scripts/horus-analyze.js",
    "horus:predict": "node scripts/horus-predict.js",
    "horus:scale": "node scripts/horus-autoscale.js",
    "horus:dashboard": "node scripts/horus-dashboard.js"
  },
  "dependencies": {
    "axios": "1.7.9",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.20.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.0.0",
    "joi": "^17.9.2",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.1",
    "mongoose": "^7.5.1",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.2.0",
    "artillery": "^2.0.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.0.3",
    "supertest": "^6.3.4"
  },
  "overrides": {
    "axios": "1.7.9"
  },
  "resolutions": {
    "axios": "1.7.9"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "author": "PureHomes Dev Team",
  "license": "MIT",
  "horus": {
    "algorithm": {
      "name": "Holistic Observation & Real-time Unified Scaling",
      "version": "1.0.0",
      "description": "Predictive auto-scaling based on real-time metrics"
    },
    "scaling": {
      "minInstances": 2,
      "maxInstances": 50,
      "targetCPUUtilization": 70,
      "targetMemoryUtilization": 80,
      "targetLatencyMs": 100,
      "cooldownSeconds": 60,
      "scaleUpThreshold": 0.8,
      "scaleDownThreshold": 0.3
    },
    "prediction": {
      "windowMinutes": 10,
      "lookaheadMinutes": 5,
      "algorithm": "exponential-smoothing",
      "alpha": 0.3,
      "beta": 0.2
    },
    "metrics": {
      "collectIntervalSeconds": 10,
      "exportPort": 9090,
      "retentionMinutes": 60
    },
    "alerts": {
      "highLatency": 500,
      "highErrorRate": 0.05,
      "lowHealthScore": 0.6
    }
  },
  "irs": {
    "algorithm": {
      "name": "Intelligent Request Shaping",
      "version": "2.0.0",
      "description": "Adaptive rate limiting with predictive backpressure"
    },
    "rateLimits": {
      "default": {
        "windowMs": 60000,
        "max": 1000
      },
      "orders": {
        "windowMs": 60000,
        "max": 100
      },
      "admin": {
        "windowMs": 60000,
        "max": 500
      },
      "health": {
        "windowMs": 60000,
        "max": 10000
      }
    },
    "shaping": {
      "enabled": true,
      "queueMaxSize": 5000,
      "slaToleranceMs": 50,
      "priorityLevels": 4
    },
    "adaptive": {
      "enabled": true,
      "adjustmentIntervalMs": 30000,
      "smoothingFactor": 0.3,
      "minRateLimit": 10,
      "maxRateLimit": 10000
    }
  },
  "dosa": {
    "algorithm": {
      "name": "Dynamic Order Scoring Algorithm",
      "version": "1.0.0",
      "description": "Priority scoring for order processing"
    },
    "weights": {
      "userWeight": 0.4,
      "stockWeight": 0.4,
      "timeWeight": 0.2
    },
    "scoring": {
      "maxScore": 100,
      "minScore": 0,
      "decayFactor": 0.95
    }
  },
  "monitoring": {
    "healthCheck": {
      "path": "/health",
      "intervalSeconds": 30,
      "timeoutSeconds": 5
    },
    "metrics": {
      "path": "/metrics",
      "format": "prometheus",
      "includeSystemMetrics": true
    },
    "logging": {
      "level": "info",
      "format": "json",
      "outputs": [
        "console",
        "file"
      ]
    }
  },
  "performance": {
    "maxConcurrentRequests": 10000,
    "requestTimeoutMs": 30000,
    "keepAliveTimeoutMs": 75000,
    "headersTimeoutMs": 60000,
    "bodyLimit": "10mb",
    "parameterLimit": 5000
  },
  "security": {
    "rateLimit": {
      "enabled": true,
      "trustProxy": true,
      "standard": {
        "windowMs": 60000,
        "max": 100
      },
      "strict": {
        "windowMs": 900000,
        "max": 5
      },
      "relaxed": {
        "windowMs": 60000,
        "max": 500
      }
    },
    "helmet": {
      "enabled": true,
      "hsts": true,
      "noSniff": true,
      "xssFilter": true
    },
    "cors": {
      "allowedOrigins": [
        "http://localhost:3000",
        "https://purehomes.com"
      ],
      "allowedMethods": [
        "GET",
        "POST",
        "PUT",
        "DELETE",
        "OPTIONS"
      ],
      "allowedHeaders": [
        "Authorization",
        "Content-Type",
        "Idempotency-Key"
      ]
    }
  },
  "deployment": {
    "container": {
      "image": "purehomes/order-service:latest",
      "port": 5003,
      "healthCheck": "/health",
      "resources": {
        "requests": {
          "cpu": "500m",
          "memory": "512Mi"
        },
        "limits": {
          "cpu": "2000m",
          "memory": "2Gi"
        }
      }
    },
    "kubernetes": {
      "replicas": 3,
      "hpa": {
        "enabled": true,
        "minReplicas": 2,
        "maxReplicas": 50,
        "targetCPUUtilization": 70,
        "targetMemoryUtilization": 80
      },
      "pdb": {
        "minAvailable": 2
      }
    }
  },
  "circuitBreaker": {
    "default": {
      "failureThreshold": 5,
      "timeoutMs": 30000,
      "halfOpenRequests": 3,
      "monitorIntervalMs": 5000
    },
    "userService": {
      "failureThreshold": 3,
      "timeoutMs": 15000,
      "halfOpenRequests": 2
    },
    "productService": {
      "failureThreshold": 3,
      "timeoutMs": 15000,
      "halfOpenRequests": 2
    }
  },
  "cache": {
    "ttl": {
      "user": 60,
      "product": 30,
      "order": 300
    },
    "maxSize": 10000,
    "checkPeriod": 60
  },
  "retry": {
    "maxRetries": 3,
    "initialDelayMs": 1000,
    "maxDelayMs": 10000,
    "backoffMultiplier": 2,
    "retryableErrors": [
      "ECONNRESET",
      "ETIMEDOUT",
      "5xx"
    ]
  },
  "batch": {
    "orderProcessing": {
      "batchSize": 100,
      "concurrency": 5,
      "delayMs": 1000
    },
    "reservationCleanup": {
      "batchSize": 500,
      "intervalMs": 60000
    }
  }
}
